  "keyFeatures": [
    "End-to-end encryption with RSA-2048 and AES-256-EAX",
    "Challenge-response authentication using HMAC-SHA256",
    "TLS/SSL transport layer security",
    "Encrypted file sharing with chunked transfers",
    "Broadcast and private messaging modes",
    "Password-based key derivation with PBKDF2"
  ],
  "publicApiSurface": [
    "server.py - Message broker and authentication server",
    "client.py - Terminal-based messaging client",
    "user_store.py - User authentication and database management",
    "generate_certificates.py - SSL certificate generation utility",
    "/room <user> - Enter private chat room",
    "/msg <user> <text> - Send private message",
    "/sendfile <user> <path> - Send encrypted file",
    "/acceptfile - Accept file transfer",
    "/users - List online users",
    "/history - View message history"
  ]
